{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Details of the neck fan product.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "stock": { "type": "number" },
        "imageUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order for a neck fan.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered", "cancelled"] },
        "total": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "address", "phone", "status", "total", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "authorized admin users.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Available products in the store."
    },
    "orders": {
      "schema": "Order",
      "description": "Customer orders history."
    },
    "admins": {
      "schema": "Admin",
      "description": "List of authorized administrators."
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == 'chuirmart@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validations ---

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'stock']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0 &&
             (data.keys().size() >= 3 && data.keys().size() <= 10);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'address', 'phone', 'status', 'total', 'createdAt']) &&
             data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 100 &&
             data.address is string && data.address.size() > 0 && data.address.size() <= 1000 &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15 &&
             data.status in ['pending', 'confirmed', 'shipped', 'delivered', 'cancelled'] &&
             data.total is number && data.total >= 0 &&
             data.createdAt == request.time;
    }

    // --- Collection Matches ---

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'originalPrice', 'stock', 'imageUrl', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Admin can manage all orders
      allow get, update, delete: if isAdmin();
      allow list: if isAdmin();
      
      // Public can create orders
      allow create: if isValidOrder(incoming());
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
